<UserControl x:Class="MDB.Launcher.Views.ModListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MDB.Launcher.ViewModels"
             xmlns:conv="clr-namespace:MDB.Launcher.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ModListViewModel}"
             d:DesignWidth="800" d:DesignHeight="600">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="32,24"
                    Visibility="{Binding HasProfile, Converter={StaticResource InvBoolToVis}}">
            <TextBlock Style="{StaticResource H1}" Text="Mods" Margin="0,0,0,8" />
            <TextBlock Style="{StaticResource Body}"
                       Text="No profiles added. Create a game profile on the Home page to get started."
                       Foreground="{StaticResource TextMutedBrush}"
                       Visibility="{Binding HasAnyProfiles, Converter={StaticResource InvBoolToVis}}" />
            <TextBlock Style="{StaticResource Body}"
                       Text="Select a game profile on the Home page to view installed mods."
                       Foreground="{StaticResource TextMutedBrush}"
                       Visibility="{Binding HasAnyProfiles, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <DockPanel Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="32,24,32,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource H1}" Text="Installed Mods" />
                    <TextBlock Style="{StaticResource H1}"
                               Text="{Binding ActiveGameName, StringFormat=' — {0}'}"
                               Foreground="{StaticResource MdbPurpleBrush}"
                               Visibility="{Binding ActiveGameName, Converter={StaticResource StringToVis}}" />
                </StackPanel>

                <TextBlock Style="{StaticResource Body}"
                           Text="{Binding ModCountText}"
                           Margin="0,0,0,12" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource MdbTextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="🔍 Search mods..."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"
                                   FontSize="13"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="1"
                            Style="{StaticResource MdbSecondaryButton}"
                            Content="🔄 Refresh"
                            Command="{Binding RefreshModsCommand}"
                            Padding="12,6" />
                </Grid>
            </StackPanel>

            <!-- Loading -->
            <ProgressBar DockPanel.Dock="Top"
                         Style="{StaticResource MdbProgressBar}"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                         Margin="32,0" />

            <!-- Mod List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="32,8,32,16">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding FilteredMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MdbCard}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Mod Info -->
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <!-- Status indicator -->
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding IsEnabled, Converter={StaticResource BoolToStatusBrush}}"
                                                         Margin="0,0,10,0"
                                                         VerticalAlignment="Center" />

                                                <TextBlock Style="{StaticResource H3}"
                                                           Text="{Binding Name}"
                                                           VerticalAlignment="Center" />

                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding Version, StringFormat='  v{0}'}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MdbPurpleBrush}"
                                                           Margin="8,0,0,0" />
                                            </StackPanel>

                                            <TextBlock Style="{StaticResource Body}"
                                                       Text="{Binding Description}"
                                                       Margin="0,0,0,4"
                                                       Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVis}}" />

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding Author, StringFormat='by {0}'}"
                                                           Margin="0,0,16,0" />
                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding FileSizeFormatted}"
                                                           Margin="0,0,16,0" />
                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding Id}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Metadata error -->
                                            <TextBlock Style="{StaticResource Caption}"
                                                       Text="{Binding MetadataError}"
                                                       Foreground="{StaticResource StatusWarningBrush}"
                                                       Margin="0,4,0,0"
                                                       Visibility="{Binding HasMetadata, Converter={StaticResource InvBoolToVis}}" />
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource MdbSecondaryButton}"
                                                    Content="{Binding IsEnabled,
                                                             Converter={conv:BoolToTextConverter},
                                                             ConverterParameter='Disable|Enable'}"
                                                    Command="{Binding DataContext.ToggleModCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,6" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ═══ Mod Development ═══ -->
                    <Border Style="{StaticResource MdbCard}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource H2}" Text="Mod Development" Margin="0,0,0,4" />
                            <TextBlock Style="{StaticResource Body}"
                                       Text="Create a new mod project from the official MDB template."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,16" />

                            <!-- Mod Name -->
                            <TextBlock Style="{StaticResource Caption}" Text="MOD NAME" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <TextBox x:Name="ModNameBox"
                                         Style="{StaticResource MdbTextBox}"
                                         Text="{Binding NewModName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="e.g. MyFirstMod"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"
                                           FontSize="13"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=ModNameBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <!-- Output Directory -->
                            <TextBlock Style="{StaticResource Caption}" Text="OUTPUT DIRECTORY" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                    <TextBox x:Name="OutputDirBox"
                                             Style="{StaticResource MdbTextBox}"
                                             Text="{Binding NewModOutputDir, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Desktop (default)"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0"
                                               FontSize="13"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=OutputDirBox}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="1"
                                        Style="{StaticResource MdbSecondaryButton}"
                                        Content="📁 Browse"
                                        Command="{Binding BrowseOutputDirCommand}"
                                        Padding="12,8" />
                            </Grid>

                            <!-- Create Button + Status -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Style="{StaticResource MdbPrimaryButton}"
                                        Content="📝 Create Mod Project"
                                        Command="{Binding CreateModFromTemplateCommand}"
                                        IsEnabled="{Binding IsCreatingMod, Converter={conv:InverseBoolConverter}}"
                                        Padding="20,12"
                                        Margin="0,0,12,0" />

                                <ProgressBar Style="{StaticResource MdbProgressBar}"
                                             IsIndeterminate="True"
                                             Width="120"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsCreatingMod, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <!-- Status Message -->
                            <TextBlock Style="{StaticResource Body}"
                                       Text="{Binding CreateModStatus}"
                                       Foreground="{StaticResource MdbPurpleBrush}"
                                       Visibility="{Binding CreateModStatus, Converter={StaticResource StringToVis}}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
