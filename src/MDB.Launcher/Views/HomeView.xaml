<UserControl x:Class="MDB.Launcher.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MDB.Launcher.ViewModels"
             xmlns:conv="clr-namespace:MDB.Launcher.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:HomeViewModel}"
             d:DesignWidth="800" d:DesignHeight="600">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:ExeIconConverter x:Key="ExeIconConv" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="RootScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24">

                <!-- Header -->
                <TextBlock Style="{StaticResource H1}" Text="Home" Margin="0,0,0,8" />
                <TextBlock Style="{StaticResource Body}" Text="Manage game profiles, launch games, and inject MDB." Margin="0,0,0,24" />

                <!-- ═══ Game Profiles ═══ -->
                <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Game Profiles" Margin="0,0,0,12" />

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0,0,0,8"
                                      PreviewMouseWheel="ListBox_PreviewMouseWheel">
                            <StackPanel Orientation="Horizontal">
                                <!-- Game Cards -->
                                <ListBox ItemsSource="{Binding DataContext.Profiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                         SelectedItem="{Binding DataContext.ActiveProfile, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Focusable="False"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         PreviewMouseWheel="ListBox_PreviewMouseWheel">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0,0,8,0" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="card"
                                                                Background="{StaticResource BgDarkBrush}"
                                                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="{StaticResource RadiusMedium}"
                                                                Padding="16,12"
                                                                MinHeight="110"
                                                                Width="130">
                                                            <ContentPresenter VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="card" Property="Background" Value="{StaticResource BgCardHoverBrush}" />
                                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource MdbPurpleDarkBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource MdbBlueBrush}" />
                                                                <Setter TargetName="card" Property="Background" Value="{StaticResource BgCardBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <Image Source="{Binding GameExePath, Converter={StaticResource ExeIconConv}}"
                                                       Width="48" Height="48"
                                                       Margin="0,0,0,8"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="106" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Add Game Card -->
                                <Button Command="{Binding AddProfileCommand}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="addCard"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                                    BorderThickness="2"
                                                    CornerRadius="{StaticResource RadiusMedium}"
                                                    Padding="16,12"
                                                    MinHeight="110"
                                                    Width="130">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="+"
                                                               FontSize="32"
                                                               FontWeight="Light"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,4" />
                                                    <TextBlock Text="Add Game"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="addCard" Property="Background" Value="{StaticResource BgCardHoverBrush}" />
                                                    <Setter TargetName="addCard" Property="BorderBrush" Value="{StaticResource MdbPurpleBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Remove Profile -->
                        <Button Style="{StaticResource MdbDangerButton}"
                                Content="Remove Profile"
                                Command="{Binding RemoveProfileCommand}"
                                Padding="12,6"
                                HorizontalAlignment="Right"
                                Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- ═══ Profile Details ═══ -->
                <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16"
                        Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Profile Details" Margin="0,0,0,12" />

                        <!-- Game EXE Path -->
                        <TextBlock Style="{StaticResource Caption}" Text="GAME EXECUTABLE" Margin="0,0,0,4" />
                        <TextBlock Style="{StaticResource Mono}"
                                   Text="{Binding DataContext.ActiveProfile.GameExePath, RelativeSource={RelativeSource AncestorType=Window}}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,12" />

                        <!-- IL2CPP Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding IsIl2CppGame, Converter={StaticResource BoolToStatusBrush}}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource Body}"
                                       Foreground="{Binding IsIl2CppGame, Converter={StaticResource BoolToStatusBrush}}"
                                       Text="{Binding IsIl2CppGame, Converter={conv:BoolToTextConverter}, ConverterParameter='IL2CPP Game Detected|Not an IL2CPP game'}" />
                        </StackPanel>

                        <!-- Bridge Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding BridgeFound, Converter={StaticResource BoolToStatusBrush}}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource Body}"
                                       Text="{Binding BridgeStatusText}"
                                       Foreground="{Binding BridgeFound, Converter={StaticResource BoolToStatusBrush}}" />
                        </StackPanel>

                        <!-- Browse Bridge DLL (shown when bridge not found) -->
                        <Button Style="{StaticResource MdbSecondaryButton}"
                                Content="Browse for MDB_Bridge.dll..."
                                Command="{Binding BrowseBridgeDllCommand}"
                                Padding="12,6"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{Binding BridgeFound, Converter={StaticResource InvBoolToVis}}" />

                        <!-- Download MDB Framework (shown when bridge not found and not already downloading) -->
                        <Border Margin="0,12,0,0"
                                Background="{StaticResource BgDarkBrush}"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Padding="16,12"
                                Visibility="{Binding BridgeFound, Converter={StaticResource InvBoolToVis}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Caption}" Text="OR DOWNLOAD AUTOMATICALLY" Margin="0,0,0,8" />

                                <Button Style="{StaticResource MdbPrimaryButton}"
                                        Content="📥 Download MDB Framework"
                                        Command="{Binding DownloadMdbCommand}"
                                        IsEnabled="{Binding IsDownloadingMdb, Converter={conv:InverseBoolConverter}}"
                                        Padding="16,10"
                                        HorizontalAlignment="Left" />

                                <!-- Download progress -->
                                <StackPanel Visibility="{Binding IsDownloadingMdb, Converter={StaticResource BoolToVis}}"
                                            Margin="0,10,0,0">
                                    <ProgressBar Style="{StaticResource MdbProgressBar}"
                                                 Value="{Binding MdbDownloadPercent}"
                                                 Maximum="100"
                                                 Height="6"
                                                 Margin="0,0,0,6" />
                                    <TextBlock Style="{StaticResource Caption}"
                                               Text="{Binding MdbDownloadStatus}"
                                               Foreground="{StaticResource MdbPurpleBrush}" />
                                </StackPanel>

                                <!-- Download result (shown after completion, hidden while downloading) -->
                                <TextBlock Text="{Binding MdbDownloadStatus}"
                                           Foreground="{StaticResource MdbPurpleBrush}"
                                           Margin="0,6,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                            <Setter Property="Visibility" Value="{Binding MdbDownloadStatus, Converter={StaticResource StringToVis}}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDownloadingMdb}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Separator Style="{StaticResource MdbSeparator}" Margin="0,12" />

                        <!-- Quick Links -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MdbSecondaryButton}"
                                    Content="📁 Game Folder"
                                    Command="{Binding OpenGameFolderCommand}"
                                    Padding="12,6"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource MdbSecondaryButton}"
                                    Content="📂 Mods Folder"
                                    Command="{Binding OpenModsFolderCommand}"
                                    Padding="12,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Launch & Inject ═══ -->
                <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16"
                        Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Launch &amp; Inject" Margin="0,0,0,12" />

                        <TextBlock Style="{StaticResource Body}" Margin="0,0,0,16"
                                   Text="Start the game and automatically inject MDB_Bridge.dll once GameAssembly.dll is loaded." />

                        <!-- Injection Status -->
                        <TextBlock Style="{StaticResource Body}"
                                   Text="{Binding InjectionStatus}"
                                   Foreground="{StaticResource MdbPurpleBrush}"
                                   Visibility="{Binding InjectionStatus, Converter={StaticResource StringToVis}}"
                                   Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MdbPrimaryButton}"
                                    Content="🚀 Launch &amp; Inject"
                                    Command="{Binding LaunchAndInjectCommand}"
                                    IsEnabled="{Binding IsInjecting, Converter={conv:InverseBoolConverter}}"
                                    Padding="20,12"
                                    Margin="0,0,12,0" />

                            <Button Style="{StaticResource MdbSecondaryButton}"
                                    Content="⚡ Inject"
                                    Command="{Binding InjectIntoRunningCommand}"
                                    IsEnabled="{Binding IsInjecting, Converter={conv:InverseBoolConverter}}"
                                    Padding="20,12" />
                        </StackPanel>

                        <!-- Loading indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    Visibility="{Binding IsInjecting, Converter={StaticResource BoolToVis}}">
                            <ProgressBar Style="{StaticResource MdbProgressBar}"
                                         IsIndeterminate="True"
                                         Width="200"
                                         Margin="0,0,12,0" />
                            <TextBlock Style="{StaticResource Caption}" Text="Injection in progress..." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
