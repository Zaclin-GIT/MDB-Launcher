<UserControl x:Class="MDB.Launcher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MDB.Launcher.ViewModels"
             xmlns:conv="clr-namespace:MDB.Launcher.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             d:DesignWidth="800" d:DesignHeight="600">
    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Style="{StaticResource H1}" Text="Settings" Margin="0,0,0,8" />
            <TextBlock Style="{StaticResource Body}"
                       Text="Configure launcher behavior and preferences."
                       Margin="0,0,0,24" />

            <!-- ═══ Injection Settings ═══ -->
            <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Injection" Margin="0,0,0,16" />

                    <!-- Poll Interval -->
                    <TextBlock Style="{StaticResource Caption}" Text="POLL INTERVAL (ms)" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Body}"
                               Text="How often to check if GameAssembly.dll is loaded (in milliseconds)."
                               Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource MdbTextBox}"
                             Text="{Binding InjectionPollIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <!-- Timeout -->
                    <TextBlock Style="{StaticResource Caption}" Text="INJECTION TIMEOUT (seconds)" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Body}"
                               Text="Maximum time to wait for GameAssembly.dll before giving up."
                               Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource MdbTextBox}"
                             Text="{Binding InjectionTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <!-- Close After Injection -->
                    <CheckBox Style="{StaticResource MdbToggle}"
                              IsChecked="{Binding CloseAfterInjection}"
                              Content="Close launcher after successful injection" />
                </StackPanel>
            </Border>

            <!-- ═══ GitHub Settings ═══ -->
            <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="GitHub" Margin="0,0,0,16" />

                    <TextBlock Style="{StaticResource Caption}" Text="PERSONAL ACCESS TOKEN (optional)" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Body}"
                               Text="Provide a GitHub token to increase API rate limits (60 → 5,000 requests/hour)."
                               Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource MdbTextBox}"
                             Text="{Binding GitHubToken, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <!-- ═══ Info ═══ -->
            <Border Style="{StaticResource MdbCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="About" Margin="0,0,0,12" />

                    <TextBlock Style="{StaticResource Caption}" Text="CONFIG FILE" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Mono}"
                               Text="{Binding ConfigFilePath}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <TextBlock Style="{StaticResource Caption}" Text="VERSION" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Mono}" Text="MDB Launcher v1.0.0" />
                </StackPanel>
            </Border>

            <!-- ═══ Actions ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Style="{StaticResource MdbPrimaryButton}"
                        Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        Padding="20,12"
                        Margin="0,0,12,0" />
                <Button Style="{StaticResource MdbSecondaryButton}"
                        Content="Reset to Defaults"
                        Command="{Binding ResetDefaultsCommand}"
                        Padding="20,12" />
            </StackPanel>

            <!-- Save Status -->
            <TextBlock Style="{StaticResource Body}"
                       Text="{Binding SaveStatus}"
                       Foreground="{StaticResource StatusSuccessBrush}"
                       Visibility="{Binding SaveStatus, Converter={StaticResource StringToVis}}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
