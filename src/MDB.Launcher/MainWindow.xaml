<Window x:Class="MDB.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MDB.Launcher.ViewModels"
        xmlns:views="clr-namespace:MDB.Launcher.Views"
        xmlns:conv="clr-namespace:MDB.Launcher.Converters"
        mc:Ignorable="d"
        Title="MDB Launcher"
        Icon="Assets/mdb_full_icon.ico"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Background="{StaticResource BgDarkestBrush}"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />

        <!-- View Template Mapping -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModListViewModel}">
            <views:ModListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModDownloadViewModel}">
            <views:ModDownloadView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocsViewModel}">
            <views:DocsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════
             WINDOW CHROME BUTTONS
             ═══════════════════════════ -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,0,0,0"
                    Panel.ZIndex="100"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="MinimizeBtn" Style="{StaticResource ChromeButton}" Content="—" Click="MinimizeClick" />
            <Button x:Name="CloseBtn" Style="{StaticResource ChromeCloseButton}" Content="✕" Click="CloseClick" />
        </StackPanel>

        <!-- ═══════════════════════════
             SIDEBAR
             ═══════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarGradient}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- ── Logo & Title ── -->
                <StackPanel DockPanel.Dock="Top" Margin="20,12,20,0">
                    <!-- Logo -->
                    <Border Height="120" Margin="0,0,0,8" HorizontalAlignment="Center">
                        <Image Source="Assets/mdb_logo.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <TextBlock Text="MDB Launcher"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2" />
                    <TextBlock Text="Mod Manager &amp; Injector"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />

                    <!-- Gradient accent line -->
                    <Border Height="2"
                            CornerRadius="1"
                            Background="{StaticResource MdbGradientHorizontal}"
                            Margin="16,0,16,12"
                            Opacity="0.6" />
                </StackPanel>

                <!-- ── Version / Elevation Status ── -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,16">
                    <Separator Style="{StaticResource MdbSeparator}" Margin="0,0,0,8" />
                    <TextBlock Style="{StaticResource Caption}"
                               Text="v1.0.0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="🛡"
                                   FontSize="11"
                                   Margin="0,0,4,0" />
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Administrator"
                                   Foreground="{StaticResource StatusWarningBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- ── Settings (bottom-pinned, above version) ── -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,4">
                    <RadioButton Style="{StaticResource MdbNavButton}"
                                 Content="⚙  Settings"
                                 IsChecked="{Binding SelectedNav, Converter={conv:StringEqualsConverter}, ConverterParameter=Settings}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Settings" />
                </StackPanel>

                <!-- ── Navigation ── -->
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource Caption}"
                               Text="NAVIGATION"
                               Margin="24,0,0,8" />

                    <RadioButton Style="{StaticResource MdbNavButton}"
                                 Content="🏠  Home"
                                 IsChecked="{Binding SelectedNav, Converter={conv:StringEqualsConverter}, ConverterParameter=Home}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Home" />

                    <RadioButton Style="{StaticResource MdbNavButton}"
                                 Content="📦  Mods"
                                 IsChecked="{Binding SelectedNav, Converter={conv:StringEqualsConverter}, ConverterParameter=Mods}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Mods" />

                    <RadioButton Style="{StaticResource MdbNavButton}"
                                 Content="⬇  Download"
                                 IsChecked="{Binding SelectedNav, Converter={conv:StringEqualsConverter}, ConverterParameter=Download}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Download" />

                    <!-- ── Resources ── -->
                    <TextBlock Style="{StaticResource Caption}"
                               Text="RESOURCES"
                               Margin="24,20,0,8" />

                    <RadioButton Style="{StaticResource MdbNavButton}"
                                 Content="📖  Documentation"
                                 IsChecked="{Binding SelectedNav, Converter={conv:StringEqualsConverter}, ConverterParameter=Docs}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Docs" />

                    <Button Style="{StaticResource MdbNavLinkButton}"
                            Content="☕  Support the Project"
                            Command="{Binding OpenLinkCommand}"
                            CommandParameter="https://buymeacoffee.com/winnforge" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- ── Status Bar ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,6">
                <Grid>
                    <TextBlock Style="{StaticResource Caption}"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="{Binding ActiveProfile.Name, StringFormat='Profile: {0}', FallbackValue='No profile'}"
                                   Margin="0,0,16,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <ContentControl Content="{Binding CurrentView}" Margin="0,36,0,0" />
        </DockPanel>
    </Grid>
</Window>
